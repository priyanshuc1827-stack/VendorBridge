{
  "name": "vendorbridge-backend",
  "version": "1.0.0",
  "description": "Modular Express + TypeScript + SQLite3 backend for VendorBridge ERP",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx src/db/seed.ts && tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.12",
    "@types/sqlite3": "^3.1.11",
    "kill-port": "^2.0.1",
    "tsx": "^4.10.1",
    "typescript": "^5.4.5"
  }
}
